# ──────────────────────────────────────────────────────────────────
# .env.example — copy this to .env and fill in your real values.
# NEVER commit the actual .env file.
# ──────────────────────────────────────────────────────────────────

# Required — MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority&appName=<appName>

# Required — Telegram Bot token from @BotFather
BOT_TOKEN=<your-telegram-bot-token>

# Required — Telegram private channel ID (negative number, e.g. -1001234567890)
STORAGE_CHANNEL_ID=<your-channel-id>

# Public base URL of your deployment (no trailing slash)
# For Koyeb, set this to your app's Koyeb URL after first deploy
BASE_URL=https://your-app-name.koyeb.app

# A strong random string used for internal signing
# Generate with: openssl rand -hex 32
SECRET_KEY=replace-with-a-strong-random-secret

# Maximum upload size in megabytes (default: 20)
MAX_UPLOAD_SIZE_MB=20

# Uploads allowed per IP per minute (default: 10)
RATE_LIMIT_UPLOADS_PER_MINUTE=10

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
